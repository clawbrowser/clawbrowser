#!/usr/bin/env bash
set -euo pipefail

IMAGE="${CLAWBROWSER_IMAGE:-}"
DOCKER_BIN="${CLAWBROWSER_DOCKER_BIN:-docker}"
APP_PATH="${CLAWBROWSER_APP_PATH:-}"
BACKEND="${CLAWBROWSER_BACKEND:-auto}"
RELEASE_REF="${CLAWBROWSER_RELEASE_REF:-latest}"
REPOSITORY="${CLAWBROWSER_REPOSITORY:-clawbrowser/clawbrowser}"
AUTO_INSTALL_APP="${CLAWBROWSER_AUTO_INSTALL_APP:-1}"
CACHE_HOME="${CLAWBROWSER_CACHE_HOME:-${XDG_CACHE_HOME:-${HOME}/.cache}}"
STATE_HOME="${CLAWBROWSER_STATE_HOME:-${XDG_STATE_HOME:-${HOME}/.local/state}}"
SESSION_ROOT="${CLAWBROWSER_SESSION_ROOT:-${CACHE_HOME}/clawbrowser/sessions}"
STATE_ROOT="${CLAWBROWSER_STATE_ROOT:-${STATE_HOME}/clawbrowser}"
DEFAULT_SESSION="${CLAWBROWSER_SESSION_NAME:-default}"
CONTAINER_PREFIX="${CLAWBROWSER_CONTAINER_PREFIX:-clawbrowser}"
REMOTE_DEBUG_PORT="${CLAWBROWSER_REMOTE_DEBUG_PORT:-9222}"
READINESS_TIMEOUT_SECONDS="${CLAWBROWSER_READINESS_TIMEOUT_SECONDS:-60}"
APP_READINESS_TIMEOUT_SECONDS="${CLAWBROWSER_APP_READINESS_TIMEOUT_SECONDS:-20}"
PORTABLE_RUNTIME_ROOT="${CLAWBROWSER_RUNTIME_ROOT:-${CACHE_HOME}/clawbrowser/runtime}"
PORTABLE_LOCAL_DIR="${CLAWBROWSER_PORTABLE_LOCAL_DIR:-}"
PORTABLE_RUNTIME_ARTIFACT_BASENAME="${CLAWBROWSER_PORTABLE_RUNTIME_ARTIFACT_BASENAME:-clawbrowser-portable-xvfb-linux-amd64-glibc}"
PORTABLE_RUNTIME_PLATFORM_DIR="${CLAWBROWSER_PORTABLE_RUNTIME_PLATFORM_DIR:-linux-amd64-glibc-xvfb}"
PORTABLE_DEFAULT_SCREEN="${CLAWBROWSER_SCREEN:-1920x1080x24}"
PORTABLE_DISPLAY_MIN="${CLAWBROWSER_PORTABLE_DISPLAY_MIN:-90}"
PORTABLE_DISPLAY_MAX="${CLAWBROWSER_PORTABLE_DISPLAY_MAX:-110}"
PORTABLE_XVFB_TIMEOUT_SECONDS="${CLAWBROWSER_PORTABLE_XVFB_TIMEOUT_SECONDS:-10}"
CLAWBROWSER_ALLOW_DOCKER_BACKEND="${CLAWBROWSER_ALLOW_DOCKER_BACKEND:-0}"

log() {
  printf '[clawbrowser] %s\n' "$*" >&2
}

die() {
  printf '[clawbrowser] ERROR: %s\n' "$*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage:
  clawbrowser [command] [options] [-- browser-args...]

Commands:
  start      Start or reattach to a managed browser session
  rotate     Restart the managed session with --regenerate
  status     Show whether the session is running and where CDP lives
  endpoint   Print the CDP endpoint URL for the managed session
  stop       Stop the managed session
  list       Print cached profiles from the managed session config dir
  ensure-runtime  Ensure the native Clawbrowser runtime is installed
  help       Show this help

Options for start/rotate/status/endpoint/stop/list/ensure-runtime:
  --session NAME            Session name. Default: default
  --port PORT               Host CDP port. Default: auto-select a free port
  --backend MODE            Backend mode: auto|app|portable|docker
  --image IMAGE             Docker image tag. Default: local clawbrowser:latest if present, otherwise the published release image
  --verify                  Open clawbrowser://verify when no URL is supplied
  --help                    Show this help

Browser flags:
  All remaining arguments are passed through to the browser image, so real
  browser flags such as --fingerprint, --regenerate, --country,
  --connection-type, --skip-verify, --verify-automation, --list, and
  --output=json keep working.

Backend behavior:
  In auto mode on macOS, the launcher prefers a native Clawbrowser.app and
  auto-installs Clawbrowser.app when needed, then falls back to Docker if
  native CDP startup fails.
  In auto mode on Linux, portable is preferred and Docker is used only when
  CLAWBROWSER_ALLOW_DOCKER_BACKEND=1 or when --backend docker is explicit.
  Native app readiness in auto mode uses a short timeout; override with
  CLAWBROWSER_APP_READINESS_TIMEOUT_SECONDS when needed.

Secrets:
  This launcher does not write CLAWBROWSER_API_KEY to agent-side files or shell
  startup scripts. If neither CLAWBROWSER_API_KEY nor a saved browser-managed
  config.json exists, it prompts once and then writes the key into the
  browser-managed config; the browser may manage its own config storage.

Dashboard:
  Get an API key at https://app.clawbrowser.ai
EOF
}

require_command() {
  local name="$1"
  if ! command -v "${name}" >/dev/null 2>&1; then
    die "Required command not found: ${name}"
  fi
}

sanitize_name() {
  local raw="$1"
  local sanitized
  sanitized="$(printf '%s' "${raw}" | tr -cs 'A-Za-z0-9._-' '-')"
  sanitized="${sanitized#-}"
  sanitized="${sanitized%-}"
  if [[ -z "${sanitized}" ]]; then
    sanitized="default"
  fi
  printf '%s\n' "${sanitized}"
}

session_name="${DEFAULT_SESSION}"
host_port=""
browser_mode="start"
show_verify=0
declare -a browser_args=()
backend="auto"
interrupted_start_session=""

ensure_prompt_context() {
  local config_path saved_key

  config_path="$(config_file)"
  mkdir -p "$(dirname "${config_path}")"
  chmod 700 "$(dirname "${config_path}")" 2>/dev/null || true

  if [[ -n "${CLAWBROWSER_API_KEY:-}" ]]; then
    return 0
  fi

  if [[ -f "${config_path}" ]]; then
    saved_key="$(read_api_key_from_config_file "${config_path}" 2>/dev/null || true)"
    if [[ -n "${saved_key}" ]]; then
      CLAWBROWSER_API_KEY="${saved_key}"
      export CLAWBROWSER_API_KEY
      return 0
    fi
  fi

  log "No API key found. Get one at https://app.clawbrowser.ai"

  if [[ -t 0 ]]; then
    read -r -s -p "Paste your Clawbrowser API key: " CLAWBROWSER_API_KEY
    printf '\n'
  else
    printf '%s\n' "Paste your Clawbrowser API key:"
    IFS= read -r CLAWBROWSER_API_KEY || true
  fi

  if [[ -z "${CLAWBROWSER_API_KEY}" ]]; then
    die "API key cannot be empty."
  fi
}

config_dir() {
  local base_dir="${XDG_CONFIG_HOME:-${HOME}/.config}"
  printf '%s/clawbrowser' "${base_dir}"
}

config_file() {
  printf '%s/config.json' "$(config_dir)"
}

read_api_key_from_config_file() {
  local file="$1"
  python3 - "$file" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
try:
    payload = json.loads(path.read_text())
except Exception:
    raise SystemExit(1)

api_key = payload.get("api_key")
if not api_key:
    raise SystemExit(1)

print(api_key)
PY
}

write_api_key_config_file() {
  local file="$1"
  local api_key="$2"
  python3 - "$file" "$api_key" <<'PY'
import json
import os
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
path.parent.mkdir(parents=True, exist_ok=True)
os.chmod(path.parent, 0o700)
path.write_text(json.dumps({"api_key": sys.argv[2]}, separators=(",", ":")) + "\n")
os.chmod(path, 0o600)
PY
}

seed_session_config() {
  local config_path="$1"
  local target_file="${config_path}/config.json"
  local source_file
  local persisted_key=""

  source_file="$(config_file)"

  if [[ -f "${target_file}" ]]; then
    if [[ -z "${CLAWBROWSER_API_KEY:-}" ]]; then
      persisted_key="$(read_api_key_from_config_file "${target_file}" 2>/dev/null || true)"
      if [[ -n "${persisted_key}" ]]; then
        CLAWBROWSER_API_KEY="${persisted_key}"
        export CLAWBROWSER_API_KEY
      fi
    fi
    if [[ -n "${CLAWBROWSER_API_KEY:-}" && ! -f "${source_file}" ]]; then
      write_api_key_config_file "${source_file}" "${CLAWBROWSER_API_KEY}"
      chmod 600 "${source_file}" 2>/dev/null || true
    fi
    return 0
  fi

  if [[ -f "${source_file}" ]]; then
    cp "${source_file}" "${target_file}"
    chmod 600 "${target_file}" 2>/dev/null || true
    if [[ -z "${CLAWBROWSER_API_KEY:-}" ]]; then
      persisted_key="$(read_api_key_from_config_file "${target_file}" 2>/dev/null || true)"
      if [[ -n "${persisted_key}" ]]; then
        CLAWBROWSER_API_KEY="${persisted_key}"
        export CLAWBROWSER_API_KEY
      fi
    fi
    return 0
  fi

  if [[ -n "${CLAWBROWSER_API_KEY:-}" ]]; then
    write_api_key_config_file "${source_file}" "${CLAWBROWSER_API_KEY}"
    chmod 600 "${source_file}" 2>/dev/null || true
    write_api_key_config_file "${target_file}" "${CLAWBROWSER_API_KEY}"
    chmod 600 "${target_file}" 2>/dev/null || true
  fi
}

resolve_image() {
  if [[ -n "${IMAGE}" ]]; then
    return 0
  fi

  if "${DOCKER_BIN}" image inspect clawbrowser:latest >/dev/null 2>&1; then
    IMAGE="clawbrowser:latest"
  else
    IMAGE="docker.io/clawbrowser/clawbrowser:latest"
  fi
}

is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

is_linux() {
  [[ "$(uname -s)" == "Linux" ]]
}

is_container_env() {
  [[ -f "/.dockerenv" ]] && return 0
  [[ -f "/run/.containerenv" ]] && return 0
  if [[ -r "/proc/1/cgroup" ]] && grep -Eqa '(docker|containerd|kubepods|libpod)' /proc/1/cgroup; then
    return 0
  fi
  return 1
}

host_arch() {
  case "$(uname -m)" in
    arm64|aarch64) printf '%s\n' arm64 ;;
    x86_64|amd64) printf '%s\n' x64 ;;
    *) return 1 ;;
  esac
}

native_app_asset_name() {
  if ! is_macos; then
    return 1
  fi

  case "$(host_arch)" in
    arm64) printf '%s\n' clawbrowser-macos-arm64.tar.gz ;;
    *) return 1 ;;
  esac
}

release_asset_base() {
  if [[ "${RELEASE_REF}" == "latest" ]]; then
    printf 'https://github.com/%s/releases/latest/download' "${REPOSITORY}"
  else
    printf 'https://github.com/%s/releases/download/%s' "${REPOSITORY}" "${RELEASE_REF}"
  fi
}

portable_die() {
  local code="$1"
  shift
  die "${code}: $*"
}

download_url() {
  local url="$1"
  local destination="$2"

  python3 - "${url}" "${destination}" <<'PY'
import pathlib
import sys
import urllib.request

url = sys.argv[1]
dest = pathlib.Path(sys.argv[2])
dest.parent.mkdir(parents=True, exist_ok=True)

with urllib.request.urlopen(url, timeout=60) as response:
    with dest.open("wb") as fh:
        while True:
            chunk = response.read(1024 * 1024)
            if not chunk:
                break
            fh.write(chunk)
PY
}

download_release_asset() {
  local asset_name="$1"
  local destination="$2"
  download_url "$(release_asset_base)/${asset_name}" "${destination}"
}

install_native_app_bundle() {
  local asset_name tmp_dir archive_path bundle_path target_bundle

  asset_name="$(native_app_asset_name)" || return 1
  require_command tar
  require_command mktemp

  tmp_dir="$(mktemp -d)"
  archive_path="${tmp_dir}/${asset_name}"
  target_bundle="${HOME}/.clawbrowser/Clawbrowser.app"

  if ! download_release_asset "${asset_name}" "${archive_path}"; then
    rm -rf "${tmp_dir}"
    return 1
  fi

  if ! tar -xzf "${archive_path}" -C "${tmp_dir}"; then
    rm -rf "${tmp_dir}"
    return 1
  fi

  bundle_path="$(find "${tmp_dir}" -mindepth 1 -maxdepth 3 -type d -name 'Clawbrowser.app' | head -n 1)"
  if [[ -z "${bundle_path}" ]]; then
    rm -rf "${tmp_dir}"
    return 1
  fi

  mkdir -p "$(dirname "${target_bundle}")"
  rm -rf "${target_bundle}"
  cp -R "${bundle_path}" "${target_bundle}"
  rm -rf "${tmp_dir}"
  return 0
}

resolve_app_binary() {
  local candidate bundle

  if [[ -n "${APP_PATH}" ]]; then
    if [[ "${APP_PATH}" == *.app ]]; then
      candidate="${APP_PATH}/Contents/MacOS/Clawbrowser"
    else
      candidate="${APP_PATH}"
    fi
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  fi

  if ! is_macos; then
    return 1
  fi

  local saved_bundle_path="${HOME}/.clawbrowser/app_bundle_path"
  if [[ -f "${saved_bundle_path}" ]]; then
    local saved_bundle
    saved_bundle="$(cat "${saved_bundle_path}" 2>/dev/null || true)"
    if [[ -n "${saved_bundle}" ]]; then
      candidate="${saved_bundle}/Contents/MacOS/Clawbrowser"
      if [[ -x "${candidate}" ]]; then
        printf '%s\n' "${candidate}"
        return 0
      fi
    fi
  fi

  if command -v mdfind >/dev/null 2>&1; then
    local spotlight_result
    spotlight_result="$(mdfind "kMDItemFSName == 'Clawbrowser.app'" 2>/dev/null | head -1)"
    if [[ -n "${spotlight_result}" ]]; then
      candidate="${spotlight_result}/Contents/MacOS/Clawbrowser"
      if [[ -x "${candidate}" ]]; then
        printf '%s\n' "${candidate}"
        return 0
      fi
    fi
  fi

  for bundle in \
    "${HOME}/.clawbrowser/Clawbrowser.app" \
    "${HOME}/Desktop/Clawbrowser.app" \
    "${HOME}/Downloads/Clawbrowser.app" \
    "${HOME}/Applications/Clawbrowser.app" \
    "/Applications/Clawbrowser.app"
  do
    candidate="${bundle}/Contents/MacOS/Clawbrowser"
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

resolve_app_bundle() {
  local binary_path bundle_path

  binary_path="$(resolve_app_binary)"
  bundle_path="$(python3 - "${binary_path}" <<'PY'
import pathlib
import sys

path = pathlib.Path(sys.argv[1]).resolve()
try:
    print(path.parents[2])
except IndexError:
    raise SystemExit(1)
PY
)"

  printf '%s\n' "${bundle_path}"
}

portable_platform_supported() {
  if ! is_linux; then
    return 1
  fi

  case "$(uname -m)" in
    x86_64|amd64) ;;
    *) return 1 ;;
  esac

  if command -v getconf >/dev/null 2>&1 && getconf GNU_LIBC_VERSION >/dev/null 2>&1; then
    return 0
  fi

  if command -v ldd >/dev/null 2>&1; then
    if ldd --version 2>&1 | grep -qi 'musl'; then
      return 1
    fi
    if ldd --version 2>&1 | grep -Eqi '(gnu libc|glibc)'; then
      return 0
    fi
  fi

  return 1
}

portable_runtime_tar_name() {
  printf '%s.tar.gz\n' "${PORTABLE_RUNTIME_ARTIFACT_BASENAME}"
}

portable_runtime_sha_name() {
  printf '%s.tar.gz.sha256\n' "${PORTABLE_RUNTIME_ARTIFACT_BASENAME}"
}

portable_runtime_manifest_name() {
  printf '%s.manifest.json\n' "${PORTABLE_RUNTIME_ARTIFACT_BASENAME}"
}

portable_runtime_version_from_manifest() {
  local manifest_path="$1"
  python3 - "${manifest_path}" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
payload = json.loads(path.read_text())
version = payload.get("version", "")
if isinstance(version, str):
    print(version.strip())
PY
}

portable_runtime_target_dir() {
  local runtime_version="$1"
  printf '%s/%s/%s\n' "${PORTABLE_RUNTIME_ROOT}" "${runtime_version}" "${PORTABLE_RUNTIME_PLATFORM_DIR}"
}

portable_runtime_complete_marker() {
  local runtime_dir="$1"
  printf '%s/.complete\n' "${runtime_dir}"
}

portable_browser_entrypoint_relpath() {
  local runtime_dir="$1"

  python3 - "${runtime_dir}" <<'PY'
import json
import pathlib
import sys

runtime_dir = pathlib.Path(sys.argv[1])
manifest = runtime_dir / "manifest.json"
if not manifest.exists():
    raise SystemExit(1)

payload = json.loads(manifest.read_text())
entrypoints = payload.get("entrypoints", {})
browser = entrypoints.get("browser", "clawbrowser/clawbrowser.real")
print(browser)
PY
}

portable_browser_entrypoint() {
  local runtime_dir="$1"
  local relpath
  local candidate

  if relpath="$(portable_browser_entrypoint_relpath "${runtime_dir}" 2>/dev/null)"; then
    candidate="${runtime_dir}/${relpath}"
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  fi

  if [[ -x "${runtime_dir}/clawbrowser/clawbrowser.real" ]]; then
    printf '%s\n' "${runtime_dir}/clawbrowser/clawbrowser.real"
    return 0
  fi

  if [[ -x "${runtime_dir}/clawbrowser/clawbrowser" ]]; then
    printf '%s\n' "${runtime_dir}/clawbrowser/clawbrowser"
    return 0
  fi

  return 1
}

portable_runtime_ready() {
  local runtime_dir="$1"

  [[ -f "${runtime_dir}/manifest.json" ]] || return 1
  [[ -x "${runtime_dir}/bin/Xvfb" ]] || return 1
  [[ -d "${runtime_dir}/share/X11/xkb" ]] || return 1
  portable_browser_entrypoint "${runtime_dir}" >/dev/null 2>&1 || return 1
  [[ -f "$(portable_runtime_complete_marker "${runtime_dir}")" ]] || return 1
  return 0
}

portable_runtime_dir_from_candidate() {
  local candidate="$1"
  if [[ -z "${candidate}" ]]; then
    return 1
  fi
  if [[ -d "${candidate}/${PORTABLE_RUNTIME_PLATFORM_DIR}" ]]; then
    printf '%s\n' "${candidate}/${PORTABLE_RUNTIME_PLATFORM_DIR}"
    return 0
  fi
  printf '%s\n' "${candidate}"
}

find_portable_runtime_local() {
  local candidate runtime_dir

  if [[ -n "${PORTABLE_LOCAL_DIR}" ]]; then
    runtime_dir="$(portable_runtime_dir_from_candidate "${PORTABLE_LOCAL_DIR}")"
    if portable_runtime_ready "${runtime_dir}"; then
      printf '%s\n' "${runtime_dir}"
      return 0
    fi
  fi

  if [[ ! -d "${PORTABLE_RUNTIME_ROOT}" ]]; then
    return 1
  fi

  while IFS= read -r candidate; do
    runtime_dir="$(portable_runtime_dir_from_candidate "${candidate}")"
    if portable_runtime_ready "${runtime_dir}"; then
      printf '%s\n' "${runtime_dir}"
      return 0
    fi
  done < <(find "${PORTABLE_RUNTIME_ROOT}" -mindepth 2 -maxdepth 2 -type d -name "${PORTABLE_RUNTIME_PLATFORM_DIR}" | sort -r)

  return 1
}

verify_sha256_file() {
  local file_path="$1"
  local checksum_path="$2"

  python3 - "${file_path}" "${checksum_path}" <<'PY'
import hashlib
import pathlib
import re
import sys

artifact = pathlib.Path(sys.argv[1])
checksum = pathlib.Path(sys.argv[2])

digest = hashlib.sha256(artifact.read_bytes()).hexdigest()
content = checksum.read_text().strip()
match = re.match(r"^([a-fA-F0-9]{64})\b", content)
if not match:
    raise SystemExit(2)

expected = match.group(1).lower()
raise SystemExit(0 if digest == expected else 1)
PY
}

ensure_portable_runtime() {
  if ! portable_platform_supported; then
    portable_die "PORTABLE_UNSUPPORTED_PLATFORM" "portable backend supports Linux amd64 glibc only."
  fi

  require_command tar
  require_command mktemp

  local tmp_dir manifest_file runtime_version runtime_dir
  local local_runtime_dir
  local tarball_file checksum_file stage_root extracted_root stage_runtime_dir
  local final_dir
  local tar_name sha_name manifest_name
  mkdir -p "${PORTABLE_RUNTIME_ROOT}"

  if local_runtime_dir="$(find_portable_runtime_local)"; then
    log "Using local portable runtime at ${local_runtime_dir}"
    printf '%s\n' "${local_runtime_dir}"
    return 0
  fi

  tar_name="$(portable_runtime_tar_name)"
  sha_name="$(portable_runtime_sha_name)"
  manifest_name="$(portable_runtime_manifest_name)"

  tmp_dir="$(mktemp -d "${PORTABLE_RUNTIME_ROOT}/.download.XXXXXX")"
  manifest_file="${tmp_dir}/${manifest_name}"
  tarball_file="${tmp_dir}/${tar_name}"
  checksum_file="${tmp_dir}/${sha_name}"
  stage_root="${tmp_dir}/stage"
  mkdir -p "${stage_root}"

  if ! download_release_asset "${manifest_name}" "${manifest_file}"; then
    portable_die "PORTABLE_RUNTIME_DOWNLOAD_FAILED" "failed to download ${manifest_name} from $(release_asset_base)."
  fi

  runtime_version="$(portable_runtime_version_from_manifest "${manifest_file}" 2>/dev/null || true)"
  if [[ -z "${runtime_version}" ]]; then
    runtime_version="${RELEASE_REF}"
  fi

  runtime_dir="$(portable_runtime_target_dir "${runtime_version}")"
  if portable_runtime_ready "${runtime_dir}"; then
    rm -rf "${tmp_dir}" >/dev/null 2>&1 || true
    printf '%s\n' "${runtime_dir}"
    return 0
  fi

  mkdir -p "$(dirname "${runtime_dir}")"

  if ! download_release_asset "${tar_name}" "${tarball_file}"; then
    portable_die "PORTABLE_RUNTIME_DOWNLOAD_FAILED" "failed to download ${tar_name} from $(release_asset_base)."
  fi

  if ! download_release_asset "${sha_name}" "${checksum_file}"; then
    portable_die "PORTABLE_RUNTIME_DOWNLOAD_FAILED" "failed to download ${sha_name} from $(release_asset_base)."
  fi

  if ! verify_sha256_file "${tarball_file}" "${checksum_file}"; then
    portable_die "PORTABLE_RUNTIME_CHECKSUM_FAILED" "sha256 mismatch for ${tar_name}; partial download removed."
  fi

  if ! tar -xzf "${tarball_file}" -C "${stage_root}"; then
    portable_die "PORTABLE_RUNTIME_UNPACK_FAILED" "failed to unpack ${tar_name}."
  fi

  extracted_root="$(find "${stage_root}" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
  if [[ -z "${extracted_root}" ]]; then
    portable_die "PORTABLE_RUNTIME_UNPACK_FAILED" "archive did not contain a runtime directory."
  fi

  if [[ -d "${extracted_root}/${PORTABLE_RUNTIME_PLATFORM_DIR}" ]]; then
    stage_runtime_dir="${extracted_root}/${PORTABLE_RUNTIME_PLATFORM_DIR}"
  else
    stage_runtime_dir="${extracted_root}"
  fi

  cp "${manifest_file}" "${stage_runtime_dir}/manifest.json"
  touch "${stage_runtime_dir}/.complete"

  final_dir="${runtime_dir}.tmp.$$"
  rm -rf "${final_dir}"
  mv "${stage_runtime_dir}" "${final_dir}"
  rm -rf "${runtime_dir}"
  mv "${final_dir}" "${runtime_dir}"
  chmod -R u+rwX "${runtime_dir}" >/dev/null 2>&1 || true

  if ! portable_runtime_ready "${runtime_dir}"; then
    portable_die "PORTABLE_RUNTIME_UNPACK_FAILED" "runtime extracted but required files are missing in ${runtime_dir}."
  fi

  rm -rf "${tmp_dir}" >/dev/null 2>&1 || true
  printf '%s\n' "${runtime_dir}"
}

allocate_display() {
  local display
  for ((display=PORTABLE_DISPLAY_MIN; display<=PORTABLE_DISPLAY_MAX; display++)); do
    if [[ -e "/tmp/.X11-unix/X${display}" ]]; then
      continue
    fi
    if [[ -e "/tmp/.X${display}-lock" ]]; then
      continue
    fi
    printf ':%s\n' "${display}"
    return 0
  done
  return 1
}

wait_for_x_socket() {
  local display="$1"
  local timeout_seconds="${2:-${PORTABLE_XVFB_TIMEOUT_SECONDS}}"
  local display_number="${display#:}"
  local socket_path="/tmp/.X11-unix/X${display_number}"
  local deadline

  deadline="$(python3 - <<PY
import time
print(time.time() + ${timeout_seconds})
PY
)"

  while :; do
    if [[ -S "${socket_path}" ]]; then
      return 0
    fi
    if python3 - "${deadline}" <<'PY'
import sys
import time
deadline = float(sys.argv[1])
sys.exit(0 if time.time() > deadline else 1)
PY
    then
      return 1
    fi
    sleep 0.1
  done
}

ensure_portable_xkbcomp_binding() {
  local runtime_dir="$1"
  local runtime_xkbcomp="${runtime_dir}/bin/xkbcomp"
  local system_xkbcomp="/usr/bin/xkbcomp"

  if [[ -x "${system_xkbcomp}" ]]; then
    return 0
  fi

  if [[ ! -x "${runtime_xkbcomp}" ]]; then
    portable_die "PORTABLE_XVFB_FAILED" "runtime xkbcomp binary is missing at ${runtime_xkbcomp}."
  fi

  if ln -sfn "${runtime_xkbcomp}" "${system_xkbcomp}" >/dev/null 2>&1; then
    log "Linked portable xkbcomp into ${system_xkbcomp}"
    return 0
  fi

  if cp -f "${runtime_xkbcomp}" "${system_xkbcomp}" >/dev/null 2>&1; then
    chmod +x "${system_xkbcomp}" >/dev/null 2>&1 || true
    log "Copied portable xkbcomp into ${system_xkbcomp}"
    return 0
  fi

  portable_die "PORTABLE_XVFB_FAILED" "${system_xkbcomp} is missing and could not be installed from runtime payload."
}

assert_not_headless_args() {
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --headless|--headless=*|--headless=new|--headless=old)
        portable_die "PORTABLE_BROWSER_LAUNCH_FAILED" "portable backend does not allow Chromium headless mode."
        ;;
    esac
  done
}

choose_backend() {
  case "${BACKEND}" in
    auto|app|portable|docker) ;;
    *) die "Unknown backend: ${BACKEND}. Expected one of: auto, app, portable, docker." ;;
  esac

  if [[ "${BACKEND}" == "app" ]]; then
    if resolve_app_binary >/dev/null 2>&1; then
      backend="app"
      return 0
    fi
    if [[ "${AUTO_INSTALL_APP}" == "1" ]] && install_native_app_bundle; then
      if resolve_app_binary >/dev/null 2>&1; then
        log "Installed Clawbrowser.app into ${HOME}/.clawbrowser/Clawbrowser.app"
        backend="app"
        return 0
      fi
    fi
    die "CLAWBROWSER_BACKEND=app was requested, but no Clawbrowser.app bundle was found."
  fi

  if [[ "${BACKEND}" == "portable" ]]; then
    if portable_platform_supported; then
      backend="portable"
      return 0
    fi
    portable_die "PORTABLE_UNSUPPORTED_PLATFORM" "--backend portable requires Linux amd64 glibc."
  fi

  if [[ "${BACKEND}" == "docker" ]]; then
    backend="docker"
    return 0
  fi

  if is_macos; then
    if resolve_app_binary >/dev/null 2>&1; then
      backend="app"
      return 0
    fi
    if [[ "${AUTO_INSTALL_APP}" == "1" ]] && install_native_app_bundle; then
      if resolve_app_binary >/dev/null 2>&1; then
        log "Installed Clawbrowser.app into ${HOME}/.clawbrowser/Clawbrowser.app"
        backend="app"
        return 0
      fi
    fi
    backend="docker"
    return 0
  fi

  if is_linux; then
    if portable_platform_supported; then
      backend="portable"
      return 0
    fi

    if [[ "${CLAWBROWSER_ALLOW_DOCKER_BACKEND}" == "1" ]]; then
      backend="docker"
      return 0
    fi

    if is_container_env; then
      portable_die "PORTABLE_UNSUPPORTED_PLATFORM" "portable backend is unavailable and Docker fallback is disabled inside this container. Set CLAWBROWSER_ALLOW_DOCKER_BACKEND=1 to force Docker."
    fi

    portable_die "PORTABLE_UNSUPPORTED_PLATFORM" "portable backend supports Linux amd64 glibc only. Set CLAWBROWSER_ALLOW_DOCKER_BACKEND=1 to allow Docker fallback."
  fi

  backend="docker"
}

session_dir() {
  printf '%s/%s' "${SESSION_ROOT}" "$1"
}

session_config_dir() {
  printf '%s/config' "$(session_dir "$1")"
}

state_file() {
  printf '%s/%s/state.env' "${STATE_ROOT}" "$1"
}

load_state() {
  local name="$1"
  local file
  file="$(state_file "${name}")"
  container_name=""
  host_port=""
  image=""
  backend=""
  pid=""
  runtime_dir=""
  display=""
  xvfb_pid=""
  browser_config_dir=""
  profile_dir=""
  display_backend=""
  runtime_version=""
  runtime_platform=""
  runtime_kind=""
  sandbox=""
  launcher_pid=""
  screen=""
  browser_log=""
  xvfb_log=""
  launcher_log=""
  if [[ -f "${file}" ]]; then
    # shellcheck disable=SC1090
    source "${file}"
  fi
}

write_state_kv() {
  local key="$1"
  local value="$2"
  printf '%s=%q\n' "${key}" "${value}"
}

save_state() {
  local name="$1"
  local container_name="$2"
  local port="$3"
  local current_backend="${4:-docker}"
  local pid="${5:-}"
  local file
  shift 5
  file="$(state_file "${name}")"
  mkdir -p "$(dirname "${file}")"
  chmod 700 "$(dirname "${file}")" 2>/dev/null || true
  {
    write_state_kv "session_name" "${name}"
    write_state_kv "container_name" "${container_name}"
    write_state_kv "host_port" "${port}"
    write_state_kv "image" "${IMAGE}"
    write_state_kv "backend" "${current_backend}"
    write_state_kv "pid" "${pid}"
    while (($# > 0)); do
      printf '%s\n' "$1"
      shift
    done
  } >"${file}"
}

delete_state() {
  local name="$1"
  local file
  file="$(state_file "${name}")"
  rm -f "${file}"
}

allocate_port() {
  python3 - <<'PY'
import socket
sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.bind(("127.0.0.1", 0))
print(sock.getsockname()[1])
sock.close()
PY
}

wait_for_cdp() {
  local port="$1"
  local timeout_seconds="${2:-${READINESS_TIMEOUT_SECONDS}}"
  local deadline
  deadline="$(python3 - <<PY
import time
print(time.time() + ${timeout_seconds})
PY
)"

  while :; do
    if python3 - "$port" <<'PY'
import json
import sys
import urllib.error
import urllib.request

port = sys.argv[1]
try:
    with urllib.request.urlopen(f"http://127.0.0.1:{port}/json/version", timeout=1) as response:
        payload = json.load(response)
    sys.exit(0 if payload.get("webSocketDebuggerUrl") else 1)
except Exception:
    sys.exit(1)
PY
    then
      return 0
    fi

    if python3 - "$deadline" <<'PY'
import sys
import time

deadline = float(sys.argv[1])
sys.exit(0 if time.time() > deadline else 1)
PY
    then
      return 1
    fi

    sleep 0.25
  done
}

read_cdp_endpoint() {
  local port="$1"
  python3 - "$port" <<'PY'
import json
import sys
import urllib.request

port = sys.argv[1]
with urllib.request.urlopen(f"http://127.0.0.1:{port}/json/version", timeout=2) as response:
    payload = json.load(response)
print(payload["webSocketDebuggerUrl"])
PY
}

is_cdp_alive() {
  local port="$1"
  python3 - "$port" <<'PY'
import json
import sys
import urllib.error
import urllib.request

port = sys.argv[1]
try:
    with urllib.request.urlopen(f"http://127.0.0.1:{port}/json/version", timeout=1) as response:
        payload = json.load(response)
    sys.exit(0 if payload.get("webSocketDebuggerUrl") else 1)
except Exception:
    sys.exit(1)
PY
}

find_live_native_cdp() {
  local exec_path="$1"
  local config_path="$2"
  python3 - "${exec_path}" "${config_path}" <<'PY'
import json
import re
import os
import subprocess
import sys
import urllib.request

exec_path = sys.argv[1]
exec_realpath = os.path.realpath(exec_path)
config_path = sys.argv[2]

try:
    output = subprocess.check_output(["ps", "-ax", "-o", "pid=,args="], text=True)
except Exception:
    raise SystemExit(1)

for line in output.splitlines():
    if "--type=" in line:
        continue
    if (exec_path not in line and exec_realpath not in line) or config_path not in line:
        continue

    match = re.search(r"--remote-debugging-port=(\d+)", line)
    if not match:
        continue

    port = match.group(1)
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{port}/json/version", timeout=1) as response:
            payload = json.load(response)
        if payload.get("webSocketDebuggerUrl"):
            print(line.strip().split(None, 1)[0], port)
            raise SystemExit(0)
    except Exception:
        continue

raise SystemExit(1)
PY
}

container_exists() {
  local name="$1"
  "${DOCKER_BIN}" ps --all --quiet --filter "name=^/${name}$" 2>/dev/null | head -n 1
}

stop_session() {
  local name="$1"
  local container_name="clawbrowser-${name}"
  local saved_backend="${backend:-docker}"
  local saved_pid="${pid:-}"
  local saved_xvfb_pid="${xvfb_pid:-}"
  local session_path
  local running

  load_state "${name}"
  saved_backend="${backend:-docker}"
  saved_pid="${pid:-}"
  saved_xvfb_pid="${xvfb_pid:-}"
  session_path="$(session_dir "$(sanitize_name "${name}")")"

  if [[ "${saved_backend}" == "portable" ]]; then
    if [[ -n "${saved_pid}" ]] && kill -0 "${saved_pid}" >/dev/null 2>&1; then
      kill "${saved_pid}" >/dev/null 2>&1 || true
      sleep 1
      if kill -0 "${saved_pid}" >/dev/null 2>&1; then
        kill -9 "${saved_pid}" >/dev/null 2>&1 || true
      fi
    fi
    if [[ -n "${saved_xvfb_pid}" ]] && kill -0 "${saved_xvfb_pid}" >/dev/null 2>&1; then
      kill "${saved_xvfb_pid}" >/dev/null 2>&1 || true
      sleep 1
      if kill -0 "${saved_xvfb_pid}" >/dev/null 2>&1; then
        kill -9 "${saved_xvfb_pid}" >/dev/null 2>&1 || true
      fi
    fi
    delete_state "${name}"
    return 0
  fi

  if [[ "${saved_backend}" == "app" && -n "${saved_pid}" ]]; then
    if kill -0 "${saved_pid}" >/dev/null 2>&1; then
      kill "${saved_pid}" >/dev/null 2>&1 || true
      sleep 1
    fi
    if kill -0 "${saved_pid}" >/dev/null 2>&1; then
      kill -9 "${saved_pid}" >/dev/null 2>&1 || true
    fi
    delete_state "${name}"
    return 0
  fi

  if [[ "${saved_backend}" == "app" ]]; then
    if command -v pkill >/dev/null 2>&1; then
      pkill -f -- "${session_path}/config" >/dev/null 2>&1 || true
      pkill -f -- "remote-debugging-port=${host_port:-}" >/dev/null 2>&1 || true
    fi
    delete_state "${name}"
    return 0
  fi

  running="$(container_exists "${container_name}" || true)"
  if [[ -n "${running}" ]]; then
    "${DOCKER_BIN}" stop "${container_name}" >/dev/null 2>&1 || true
  fi
  delete_state "${name}"
}

handle_start_interrupt() {
  if [[ -n "${interrupted_start_session}" ]]; then
    stop_session "${interrupted_start_session}" >/dev/null 2>&1 || true
  fi
  interrupted_start_session=""
  trap - INT TERM
  exit 130
}

launch_native_app() {
  local exec_path="$1"
  local host_port="$2"
  local session_slug="$3"
  local session_path="$4"
  local config_path="$5"
  local pid_file="${session_path}/pid"
  local log_file="${session_path}/launcher.log"
  local app_bundle
  local child_pid
  local -a launch_args=(
    --remote-debugging-address=127.0.0.1
    --remote-debugging-port="${host_port}"
    --user-data-dir="${config_path}"
    --no-first-run
    --no-default-browser-check
  )

  mkdir -p "${session_path}"
  chmod 700 "${session_path}" "${config_path}" 2>/dev/null || true

  if [[ ${#browser_args[@]} -gt 0 ]]; then
    launch_args+=("${browser_args[@]}")
  fi

  if is_macos && command -v open >/dev/null 2>&1; then
    app_bundle="$(resolve_app_bundle)"
    log "Launching native app bundle ${app_bundle} via LaunchServices"
    env -u CLAWBROWSER_API_KEY -u CLAWBROWSER_CONFIG_DIR \
      open -na "${app_bundle}" --args "${launch_args[@]}" >/dev/null 2>&1
    child_pid="$(wait_for_native_pid "${exec_path}" "${host_port}" "${config_path}" || true)"
    if [[ -z "${child_pid}" ]]; then
      if command -v pkill >/dev/null 2>&1; then
        pkill -f -- "${config_path}" >/dev/null 2>&1 || true
      fi
      return 1
    fi
    printf '%s\n' "${child_pid}" >"${pid_file}"
    printf '%s\n' "${child_pid}"
    return 0
  fi

  log "Launching native app binary ${exec_path}"
  env -u CLAWBROWSER_API_KEY -u CLAWBROWSER_CONFIG_DIR \
    nohup "${exec_path}" \
    "${launch_args[@]}" \
    >"${log_file}" 2>&1 &

  child_pid="$!"
  printf '%s\n' "${child_pid}" >"${pid_file}"
  printf '%s\n' "${child_pid}"
}

wait_for_native_pid() {
  local exec_path="$1"
  local host_port="$2"
  local config_path="$3"
  local deadline

  deadline="$(python3 - <<PY
import time
print(time.time() + ${READINESS_TIMEOUT_SECONDS})
PY
)"

  while :; do
    if python3 - "$exec_path" "$host_port" "$config_path" <<'PY'
import os
import subprocess
import sys

exec_path = sys.argv[1]
exec_realpath = os.path.realpath(exec_path)
host_port = sys.argv[2]
config_path = sys.argv[3]

try:
    output = subprocess.check_output(["ps", "-ax", "-o", "pid=,args="], text=True)
except Exception:
    sys.exit(1)

for line in output.splitlines():
    if "--type=" in line:
        continue
    if (exec_path not in line and exec_realpath not in line) or config_path not in line:
        continue

    if f"--remote-debugging-port={host_port}" in line:
        print(line.strip().split(None, 1)[0])
        sys.exit(0)

sys.exit(1)
PY
    then
      return 0
    fi

    if python3 - "$deadline" <<'PY'
import sys
import time

deadline = float(sys.argv[1])
sys.exit(0 if time.time() > deadline else 1)
PY
    then
      return 1
    fi

    sleep 0.25
  done
}

build_browser_args() {
  local skip_verify=1
  local saw_list=0
  local saw_fingerprint=0
  local saw_startup_arg=0
  local arg
  local previous_arg=""

  if [[ ${#browser_args[@]} -gt 0 ]]; then
    for arg in "${browser_args[@]}"; do
      case "${arg}" in
        --verify|--verify-automation)
          skip_verify=0
          ;;
        --skip-verify)
          skip_verify=1
          ;;
        --fingerprint|--fingerprint=*)
          saw_fingerprint=1
          ;;
        --list)
          saw_list=1
          ;;
        --remote-debugging-address=*|--remote-debugging-port=*)
          ;;
        *)
          if [[ "${arg}" != -* && "${previous_arg}" != "--fingerprint" ]]; then
            saw_startup_arg=1
          fi
          ;;
      esac
      previous_arg="${arg}"
    done
  fi

  if [[ "${show_verify}" -eq 1 || "${browser_mode}" == "list" ]]; then
    skip_verify=0
  fi

  if [[ "${saw_fingerprint}" -eq 0 && "${saw_list}" -eq 0 ]]; then
    if [[ ${#browser_args[@]} -gt 0 ]]; then
      browser_args=("--fingerprint" "${browser_args[@]}")
    else
      browser_args=("--fingerprint")
    fi
  fi

  if [[ "${skip_verify}" -eq 1 && "${saw_list}" -eq 0 ]]; then
    if [[ ${#browser_args[@]} -gt 0 ]]; then
      browser_args=("--skip-verify" "${browser_args[@]}")
    else
      browser_args=("--skip-verify")
    fi
  fi

  if [[ "${saw_startup_arg}" -eq 0 && "${saw_list}" -eq 0 ]]; then
    if [[ "${show_verify}" -eq 1 ]]; then
      browser_args+=("clawbrowser://verify")
    else
      browser_args+=("about:blank")
    fi
  fi
}

requested_startup_url() {
  local arg
  local previous_arg=""

  for arg in "${browser_args[@]}"; do
    if [[ "${arg}" != -* && "${previous_arg}" != "--fingerprint" ]]; then
      printf '%s\n' "${arg}"
      return 0
    fi
    previous_arg="${arg}"
  done

  if [[ "${show_verify}" -eq 1 ]]; then
    printf '%s\n' "clawbrowser://verify"
    return 0
  fi

  return 1
}

open_cdp_url() {
  local host_port="$1"
  local url="$2"

  python3 - "${host_port}" "${url}" <<'PY'
import json
import sys
from urllib import error, parse, request

host_port = sys.argv[1]
target = sys.argv[2]
endpoint = f"http://127.0.0.1:{host_port}/json/new?{parse.quote(target, safe='')}"

req = request.Request(endpoint, method="PUT")
try:
    with request.urlopen(req, timeout=2) as response:
        response.read()
except error.HTTPError as exc:
    if exc.code != 405:
        raise
    with request.urlopen(endpoint, timeout=2) as response:
        response.read()
PY
}

launch_portable_session() {
  local session_slug="$1"
  local host_port="$2"
  local session_path="$3"
  local config_path="$4"
  local runtime_dir browser_exec display xdg_runtime_dir
  local xvfb_log browser_log launcher_log browser_pid xvfb_process_pid runtime_version
  local -a state_lines=()

  runtime_dir="$(ensure_portable_runtime)"
  if [[ ! -w "$(dirname "${runtime_dir}")" ]]; then
    portable_die "PORTABLE_RUNTIME_NO_WRITABLE_DIR" "runtime parent directory is not writable: $(dirname "${runtime_dir}")."
  fi
  if [[ ! -x "${runtime_dir}" ]]; then
    portable_die "PORTABLE_RUNTIME_NOEXEC" "runtime directory is not executable: ${runtime_dir}."
  fi

  browser_exec="$(portable_browser_entrypoint "${runtime_dir}" 2>/dev/null || true)"
  if [[ -z "${browser_exec}" ]]; then
    portable_die "PORTABLE_BROWSER_LAUNCH_FAILED" "portable runtime browser entrypoint missing under ${runtime_dir}."
  fi

  ensure_portable_xkbcomp_binding "${runtime_dir}"

  assert_not_headless_args "${browser_args[@]}"

  display="$(allocate_display || true)"
  if [[ -z "${display}" ]]; then
    portable_die "PORTABLE_XVFB_FAILED" "no free X display available in :${PORTABLE_DISPLAY_MIN}-:${PORTABLE_DISPLAY_MAX}."
  fi

  xdg_runtime_dir="${session_path}/xdg-runtime"
  mkdir -p "${session_path}" "${config_path}" "${xdg_runtime_dir}"
  chmod 700 "${session_path}" "${config_path}" "${xdg_runtime_dir}" 2>/dev/null || true

  xvfb_log="${session_path}/xvfb.log"
  browser_log="${session_path}/browser.log"
  launcher_log="${session_path}/launcher.log"

  log "Starting portable Xvfb on ${display}"
  PORTABLE_DIR="${runtime_dir}" \
  LD_LIBRARY_PATH="${runtime_dir}/lib/x86_64-linux-gnu:${runtime_dir}/lib/usr-x86_64-linux-gnu:${LD_LIBRARY_PATH:-}" \
  FONTCONFIG_PATH="${runtime_dir}/etc/fonts" \
  XKB_CONFIG_ROOT="${runtime_dir}/share/X11/xkb" \
  XDG_DATA_DIRS="${runtime_dir}/share:${XDG_DATA_DIRS:-}" \
  XDG_RUNTIME_DIR="${xdg_runtime_dir}" \
  PATH="${runtime_dir}/bin:${PATH:-}" \
  "${runtime_dir}/bin/Xvfb" "${display}" \
    -screen 0 "${PORTABLE_DEFAULT_SCREEN}" \
    -xkbdir "${runtime_dir}/share/X11/xkb" \
    -nolisten tcp \
    >"${xvfb_log}" 2>&1 &
  xvfb_process_pid="$!"

  if ! wait_for_x_socket "${display}" "${PORTABLE_XVFB_TIMEOUT_SECONDS}"; then
    kill "${xvfb_process_pid}" >/dev/null 2>&1 || true
    portable_die "PORTABLE_XVFB_FAILED" "bundled Xvfb did not create display socket for ${display} within ${PORTABLE_XVFB_TIMEOUT_SECONDS}s. Logs: ${xvfb_log}"
  fi

  log "Starting portable browser on 127.0.0.1:${host_port}"
  DISPLAY="${display}" \
  PORTABLE_DIR="${runtime_dir}" \
  LD_LIBRARY_PATH="${runtime_dir}/lib/x86_64-linux-gnu:${runtime_dir}/lib/usr-x86_64-linux-gnu:${LD_LIBRARY_PATH:-}" \
  FONTCONFIG_PATH="${runtime_dir}/etc/fonts" \
  XKB_CONFIG_ROOT="${runtime_dir}/share/X11/xkb" \
  XDG_DATA_DIRS="${runtime_dir}/share:${XDG_DATA_DIRS:-}" \
  XDG_RUNTIME_DIR="${xdg_runtime_dir}" \
  PATH="${runtime_dir}/bin:${PATH:-}" \
  nohup "${browser_exec}" \
    --remote-debugging-address=127.0.0.1 \
    --remote-debugging-port="${host_port}" \
    --user-data-dir="${config_path}" \
    --no-first-run \
    --no-default-browser-check \
    --disable-dev-shm-usage \
    --no-sandbox \
    "${browser_args[@]}" \
    >"${browser_log}" 2>&1 &
  browser_pid="$!"

  if ! kill -0 "${browser_pid}" >/dev/null 2>&1; then
    kill "${xvfb_process_pid}" >/dev/null 2>&1 || true
    portable_die "PORTABLE_BROWSER_LAUNCH_FAILED" "portable browser process exited immediately. Logs: ${browser_log}"
  fi

  runtime_version="$(portable_runtime_version_from_manifest "${runtime_dir}/manifest.json" 2>/dev/null || true)"
  state_lines+=("$(write_state_kv "browser_config_dir" "${config_path}")")
  state_lines+=("$(write_state_kv "profile_dir" "${config_path}")")
  state_lines+=("$(write_state_kv "runtime_dir" "${runtime_dir}")")
  state_lines+=("$(write_state_kv "display_backend" "xvfb")")
  state_lines+=("$(write_state_kv "display" "${display}")")
  state_lines+=("$(write_state_kv "xvfb_pid" "${xvfb_process_pid}")")
  state_lines+=("$(write_state_kv "sandbox" "off")")
  state_lines+=("$(write_state_kv "runtime_version" "${runtime_version}")")
  state_lines+=("$(write_state_kv "runtime_platform" "linux-amd64-glibc")")
  state_lines+=("$(write_state_kv "runtime_kind" "portable-xvfb")")
  state_lines+=("$(write_state_kv "screen" "${PORTABLE_DEFAULT_SCREEN}")")
  state_lines+=("$(write_state_kv "browser_log" "${browser_log}")")
  state_lines+=("$(write_state_kv "xvfb_log" "${xvfb_log}")")
  state_lines+=("$(write_state_kv "launcher_log" "${launcher_log}")")
  state_lines+=("$(write_state_kv "launcher_pid" "$$")")
  save_state "${session_slug}" "" "${host_port}" "portable" "${browser_pid}" "${state_lines[@]}"
}

launch_docker_session() {
  local session_slug="$1"
  local container_name="$2"
  local host_port="$3"
  local config_path="$4"
  local cid

  if [[ -z "${IMAGE}" ]]; then
    resolve_image
  fi
  require_command "${DOCKER_BIN}"
  log "Starting container session ${session_slug} on 127.0.0.1:${host_port}"

  cid="$("${DOCKER_BIN}" run \
    --detach \
    --rm \
    --name "${container_name}" \
    --label "clawbrowser.session=${session_slug}" \
    --publish "127.0.0.1:${host_port}:${REMOTE_DEBUG_PORT}" \
    --env "CLAWBROWSER_API_KEY=${CLAWBROWSER_API_KEY}" \
    --env "CLAWBROWSER_CONFIG_DIR=/home/clawbrowser/.config/clawbrowser" \
    --volume "${config_path}:/home/clawbrowser/.config/clawbrowser" \
    "${IMAGE}" \
    --remote-debugging-address=127.0.0.1 \
    --remote-debugging-port="${REMOTE_DEBUG_PORT}" \
    "${browser_args[@]}")"

  save_state "${session_slug}" "${container_name}" "${host_port}" "docker"
  log "Container ${cid} launched"
}

parse_common_options() {
  while (($# > 0)); do
    case "$1" in
      --session)
        session_name="$2"
        shift 2
        ;;
      --port)
        host_port="$2"
        shift 2
        ;;
      --backend)
        BACKEND="$2"
        shift 2
        ;;
      --image)
        IMAGE="$2"
        shift 2
        ;;
      --verify)
        show_verify=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --)
        shift
        browser_args+=("$@")
        return 0
        ;;
      *)
        browser_args+=("$1")
        shift
        ;;
    esac
  done
}

start_session() {
  local session_slug container_name session_path config_path endpoint
  local app_exec pid existing_pid existing_port startup_url
  session_slug="$(sanitize_name "${session_name}")"
  container_name="${CONTAINER_PREFIX}-${session_slug}"
  session_path="$(session_dir "${session_slug}")"
  config_path="${session_path}/config"
  load_state "${session_slug}" || true
  if [[ "${BACKEND}" == "docker" && -z "${IMAGE}" ]]; then
    if [[ -n "${image:-}" ]]; then
      IMAGE="${image}"
    else
      resolve_image
    fi
  fi

  mkdir -p "${config_path}"
  chmod 700 "${session_path}" "${config_path}" 2>/dev/null || true

  if [[ -z "${host_port}" ]]; then
    host_port="$(allocate_port)"
  fi

  if is_cdp_alive "${host_port}" >/dev/null 2>&1; then
    log "Session ${session_slug} already appears to be running on ${host_port}"
    if startup_url="$(requested_startup_url 2>/dev/null)"; then
      open_cdp_url "${host_port}" "${startup_url}"
    fi
    printf '%s\n' "http://127.0.0.1:${host_port}"
    return 0
  fi

  choose_backend

  if [[ "${backend}" == "app" ]]; then
    rm -f "${config_path}/config.json" 2>/dev/null || true
  fi

  ensure_prompt_context "${session_slug}"
  seed_session_config "${config_path}"
  build_browser_args

  if [[ "${backend}" == "app" ]]; then
    app_exec="$(resolve_app_binary)"
    log "Starting native session ${session_slug} on 127.0.0.1:${host_port}"
    pid="$(launch_native_app "${app_exec}" "${host_port}" "${session_slug}" "${session_path}" "${config_path}")"
    if [[ -z "${pid}" ]]; then
      stop_session "${session_slug}"
      if [[ "${BACKEND}" == "auto" ]]; then
        log "Native app launch failed; retrying session ${session_slug} with docker backend"
        backend="docker"
        ensure_prompt_context "${session_slug}"
        seed_session_config "${config_path}"
      else
        die "Failed to launch native browser session ${session_slug}"
      fi
    else
      save_state "${session_slug}" "" "${host_port}" "app" "${pid}"
      log "Native browser launched with pid ${pid}"
    fi
  fi

  if [[ "${backend}" == "docker" ]]; then
    seed_session_config "${config_path}"
    launch_docker_session "${session_slug}" "${container_name}" "${host_port}" "${config_path}"
  fi

  if [[ "${backend}" == "portable" ]]; then
    launch_portable_session "${session_slug}" "${host_port}" "${session_path}" "${config_path}"
  fi

  interrupted_start_session="${session_slug}"
  trap 'handle_start_interrupt' INT TERM

  if [[ "${backend}" == "app" && "${BACKEND}" == "auto" ]]; then
    if ! wait_for_cdp "${host_port}" "${APP_READINESS_TIMEOUT_SECONDS}"; then
      if read -r existing_pid existing_port < <(find_live_native_cdp "${app_exec}" "${config_path}" 2>/dev/null); then
        log "Native app reused an existing browser session; attaching to 127.0.0.1:${existing_port}"
        host_port="${existing_port}"
        save_state "${session_slug}" "" "${host_port}" "app" "${existing_pid}"
      else
        log "Native session ${session_slug} did not expose CDP; falling back to docker backend"
        stop_session "${session_slug}"
        backend="docker"
        launch_docker_session "${session_slug}" "${container_name}" "${host_port}" "${config_path}"
        if ! wait_for_cdp "${host_port}"; then
          log "CDP endpoint failed to become ready after docker fallback, stopping session"
          stop_session "${session_slug}"
          die "Timed out waiting for CDP on port ${host_port}"
        fi
      fi
    fi
  else
    if ! wait_for_cdp "${host_port}"; then
      if [[ "${backend}" == "app" ]] && read -r existing_pid existing_port < <(find_live_native_cdp "${app_exec}" "${config_path}" 2>/dev/null); then
        log "Native app reused an existing browser session; attaching to 127.0.0.1:${existing_port}"
        host_port="${existing_port}"
        save_state "${session_slug}" "" "${host_port}" "app" "${existing_pid}"
      else
        log "CDP endpoint failed to become ready, stopping session"
        stop_session "${session_slug}"
        if [[ "${backend}" == "portable" ]]; then
          portable_die "PORTABLE_BROWSER_CDP_TIMEOUT" "browser did not expose CDP on 127.0.0.1:${host_port}. Logs: ${session_path}/browser.log ${session_path}/xvfb.log"
        fi
        die "Timed out waiting for CDP on port ${host_port}"
      fi
    fi
  fi

  interrupted_start_session=""
  trap - INT TERM

  local endpoint
  endpoint="http://127.0.0.1:${host_port}"
  printf '%s\n' "${endpoint}"
}

show_status() {
  local session_slug container_name host_port state_endpoint
  session_slug="$(sanitize_name "${session_name}")"
  load_state "${session_slug}"

  if [[ -z "${container_name:-}" || -z "${host_port:-}" ]]; then
    if [[ -z "${pid:-}" ]]; then
      if [[ ("${backend:-}" == "app" || "${backend:-}" == "portable") && -n "${host_port:-}" ]] && is_cdp_alive "${host_port}" >/dev/null 2>&1; then
        printf '%s\n' "session=${session_slug} status=running endpoint=http://127.0.0.1:${host_port} backend=${backend:-app}"
        return 0
      fi
      printf '%s\n' "session=${session_slug} status=stopped"
      return 0
    fi
    if ! kill -0 "${pid}" >/dev/null 2>&1; then
      printf '%s\n' "session=${session_slug} status=stopped"
      return 0
    fi
    printf '%s\n' "session=${session_slug} status=running endpoint=http://127.0.0.1:${host_port} backend=${backend:-app}"
    return 0
  fi

  state_endpoint="http://127.0.0.1:${host_port}"
  if is_cdp_alive "${host_port}" >/dev/null 2>&1; then
    printf '%s\n' "session=${session_slug} status=running endpoint=${state_endpoint} container=${container_name}"
  else
    printf '%s\n' "session=${session_slug} status=stopped endpoint=${state_endpoint} container=${container_name}"
  fi
}

print_endpoint() {
  local session_slug host_port
  session_slug="$(sanitize_name "${session_name}")"
  load_state "${session_slug}"
  if [[ -z "${host_port:-}" ]]; then
    die "No saved endpoint for session ${session_slug}"
  fi
  if ! is_cdp_alive "${host_port}" >/dev/null 2>&1; then
    die "Session ${session_slug} is not running"
  fi
  printf 'http://127.0.0.1:%s\n' "${host_port}"
}

list_profiles() {
  local session_slug session_path config_path app_exec runtime_dir browser_exec
  session_slug="$(sanitize_name "${session_name}")"
  session_path="$(session_dir "${session_slug}")"
  config_path="${session_path}/config"
  mkdir -p "${config_path}"
  chmod 700 "${session_path}" "${config_path}" 2>/dev/null || true

  choose_backend

  if [[ "${backend}" == "app" ]]; then
    app_exec="$(resolve_app_binary)"
    "${app_exec}" \
      --list \
      --output=json \
      --user-data-dir="${config_path}"
  elif [[ "${backend}" == "portable" ]]; then
    runtime_dir="$(ensure_portable_runtime)"
    browser_exec="$(portable_browser_entrypoint "${runtime_dir}")"
    mkdir -p "${session_path}/xdg-runtime-list"
    chmod 700 "${session_path}/xdg-runtime-list" 2>/dev/null || true
    PORTABLE_DIR="${runtime_dir}" \
    LD_LIBRARY_PATH="${runtime_dir}/lib/x86_64-linux-gnu:${runtime_dir}/lib/usr-x86_64-linux-gnu:${LD_LIBRARY_PATH:-}" \
    FONTCONFIG_PATH="${runtime_dir}/etc/fonts" \
    XKB_CONFIG_ROOT="${runtime_dir}/share/X11/xkb" \
    XDG_DATA_DIRS="${runtime_dir}/share:${XDG_DATA_DIRS:-}" \
    XDG_RUNTIME_DIR="${session_path}/xdg-runtime-list" \
    PATH="${runtime_dir}/bin:${PATH:-}" \
    "${browser_exec}" \
      --list \
      --output=json \
      --user-data-dir="${config_path}"
  else
    if [[ -z "${IMAGE}" ]]; then
      resolve_image
    fi
    require_command "${DOCKER_BIN}"
    local output
    output="$("${DOCKER_BIN}" run \
      --rm \
      --volume "${config_path}:/home/clawbrowser/.config/clawbrowser" \
      "${IMAGE}" \
      --list \
      --output=json)"
    printf '%s\n' "${output}" | sed '/^\[clawbrowser-docker\]/d'
  fi
}

rotate_session() {
  local session_slug
  local config_path
  local existing_args=()
  session_slug="$(sanitize_name "${session_name}")"
  stop_session "${session_slug}"
  config_path="$(session_config_dir "${session_slug}")"
  rm -rf "${config_path}"
  if [[ ${#browser_args[@]} -gt 0 ]]; then
    existing_args=("${browser_args[@]}")
  fi
  browser_args=("--regenerate")
  if [[ ${#existing_args[@]} -gt 0 ]]; then
    browser_args+=("${existing_args[@]}")
  fi
  start_session
}

ensure_runtime() {
  local app_exec runtime_dir
  choose_backend

  if [[ "${backend}" == "portable" ]]; then
    runtime_dir="$(ensure_portable_runtime)"
    printf '%s\n' "${runtime_dir}"
    return 0
  fi

  if [[ "${backend}" == "docker" ]]; then
    if [[ -n "${IMAGE}" ]]; then
      printf '%s\n' "${IMAGE}"
    else
      resolve_image
      printf '%s\n' "${IMAGE}"
    fi
    return 0
  fi

  if app_exec="$(resolve_app_binary 2>/dev/null)"; then
    printf '%s\n' "${app_exec}"
    return 0
  fi

  if [[ "${AUTO_INSTALL_APP}" != "1" ]]; then
    die "Clawbrowser.app is not installed and auto-install is disabled."
  fi

  log "Installing Clawbrowser.app into ${HOME}/.clawbrowser/Clawbrowser.app"
  install_native_app_bundle || die "Failed to install Clawbrowser.app from release assets."

  if app_exec="$(resolve_app_binary 2>/dev/null)"; then
    printf '%s\n' "${app_exec}"
    return 0
  fi

  die "Installed Clawbrowser.app but could not find executable."
}

main() {
  require_command python3

  local command="${1:-start}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "${command}" in
    start|setup)
      browser_mode="start"
      parse_common_options "$@"
      start_session
      ;;
    rotate|restart)
      browser_mode="start"
      parse_common_options "$@"
      rotate_session
      ;;
    status)
      browser_mode="status"
      parse_common_options "$@"
      show_status
      ;;
    endpoint)
      browser_mode="endpoint"
      parse_common_options "$@"
      print_endpoint
      ;;
    stop)
      browser_mode="stop"
      parse_common_options "$@"
      stop_session "$(sanitize_name "${session_name}")"
      ;;
    list)
      browser_mode="list"
      parse_common_options "$@"
      list_profiles
      ;;
    ensure-runtime)
      browser_mode="status"
      parse_common_options "$@"
      ensure_runtime
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      browser_args=("${command}" "$@")
      browser_mode="start"
      start_session
      ;;
  esac
}

main "$@"
