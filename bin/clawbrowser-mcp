#!/usr/bin/env python3
import json
import os
import shutil
import subprocess
import sys
import re
from pathlib import Path
from urllib import error as urllib_error
from urllib import parse as urllib_parse
from urllib import request as urllib_request

SERVER_NAME = "clawbrowser"
SERVER_VERSION = "1.0.0"
SERVER_INSTRUCTIONS = (
    "Clawbrowser CLI/MCP manages lifecycle and identity. Use these MCP tools "
    "instead of the user's personal/system browser or an unmanaged browser. "
    "Use start_session to create or reattach a managed session, use "
    "endpoint_session to get the CDP automation endpoint, and use CDP for "
    "navigation, clicking, typing, scraping, screenshots, DOM inspection, and "
    "JS evaluation. Managed sessions for agent tasks are expected to run in "
    "fingerprint/proxy mode; if verify reports fingerprint mode inactive, the "
    "session was not launched correctly. Use clawbrowser://verify/ for "
    "fingerprint/proxy inspection. Use rotate_session for the official "
    "fresh-identity path, use clawbrowser://verify/ only when identity, proxy, "
    "or geo proof matters, and do not launch browser binaries directly for "
    "agent tasks. On macOS, Clawbrowser.app may be the native runtime used "
    "under the hood, but agents should not invoke it directly. This server is "
    "local stdio only, not a network daemon. Treat the returned CDP endpoint "
    "as a temporary runtime handle, call endpoint_session again after start, "
    "reattach, restart, or rotate, and do not persist endpoint values into "
    "any config or project file. For fingerprint/proxy/identity inspection, "
    "open clawbrowser://verify/ inside the managed session and inspect it "
    "through CDP. If you need to write browser-managed config manually, "
    "resolve the absolute path first and do not pass unresolved shell-expression "
    "paths to file/write tools; they may create literal workspace paths instead "
    "of the real config file. Never expose CDP on the network, and never put "
    "API keys in MCP config, agent config, shell rc files, or logs."
)

ALLOWED_SESSION_URLS = {
    "about:blank",
    "clawbrowser://verify",
    "clawbrowser://verify/",
    "clawbrowser://auth",
}
ALLOWED_SESSION_SCHEMES = {"http", "https"}
SENSITIVE_KEYWORDS = (
    "api_key",
    "access_token",
    "refresh_token",
    "authorization",
    "cookie",
    "cookies",
    "token",
    "password",
)


def log(message: str) -> None:
    print(f"[clawbrowser-mcp] {message}", file=sys.stderr, flush=True)


def die(message: str) -> None:
    log(f"ERROR: {message}")
    sys.exit(1)


def launcher_path() -> str:
    env = os.environ.get("CLAWBROWSER_BIN")
    if env:
        return env

    local = Path(__file__).resolve().with_name("clawbrowser")
    if local.exists():
        return str(local)

    which = shutil.which("clawbrowser")
    if which:
        return which

    die("Could not find the clawbrowser launcher. Set CLAWBROWSER_BIN or install clawbrowser on PATH.")
    raise SystemExit(1)


def config_home_dir() -> Path:
    xdg = os.environ.get("XDG_CONFIG_HOME")
    if xdg:
        return Path(xdg)
    return Path.home() / ".config"


def saved_config_path() -> Path:
    return config_home_dir() / "clawbrowser" / "config.json"


def saved_config_has_api_key() -> bool:
    path = saved_config_path()
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return False

    api_key = payload.get("api_key")
    return isinstance(api_key, str) and bool(api_key.strip())


def read_message():
    headers = {}
    while True:
        line = sys.stdin.buffer.readline()
        if not line:
            return None
        line = line.decode("utf-8", errors="replace").rstrip("\r\n")
        if not line:
            break
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        headers[key.strip().lower()] = value.strip()

    length = int(headers.get("content-length", "0") or "0")
    if length <= 0:
        return None
    body = sys.stdin.buffer.read(length)
    if not body:
        return None
    return json.loads(body.decode("utf-8"))


def write_message(message):
    payload = json.dumps(message, separators=(",", ":")).encode("utf-8")
    sys.stdout.buffer.write(f"Content-Length: {len(payload)}\r\n\r\n".encode("ascii"))
    sys.stdout.buffer.write(payload)
    sys.stdout.buffer.flush()


def text_result(text: str):
    return {"content": [{"type": "text", "text": text}]}


def error_result(text: str):
    return {"content": [{"type": "text", "text": text}], "isError": True}


def redact_sensitive_text(text: str, api_key=None) -> str:
    if not text:
        return ""

    redacted = str(text)
    if api_key:
        redacted = redacted.replace(api_key, "<redacted>")

    redacted = re.sub(
        r"(?i)\b(CLAWBROWSER_API_KEY|api[_-]?key|access[_-]?token|refresh[_-]?token|token|cookie|cookies|authorization|password)\b(\s*[:=]\s*)([^\s,;\"']+)",
        r"\1\2<redacted>",
        redacted,
    )
    redacted = re.sub(
        r'(?i)("(?:api[_-]?key|access[_-]?token|refresh[_-]?token|token|cookie|cookies|authorization|password)"\s*:\s*")[^"]*(")',
        r"\1<redacted>\2",
        redacted,
    )

    safe_lines = []
    for line in redacted.splitlines():
        lower = line.lower()
        if any(keyword in lower for keyword in SENSITIVE_KEYWORDS):
            continue
        if "{" in line or "}" in line or "[" in line or "]" in line:
            continue
        safe_lines.append(line)

    redacted = "\n".join(safe_lines).strip()
    if len(redacted) > 500:
        redacted = redacted[:500].rstrip() + "…"
    return redacted


def launcher_failure(operation: str, session: str, code: int, stdout: str = "", stderr: str = "", api_key=None):
    detail = redact_sensitive_text(stderr or stdout, api_key=api_key)
    if detail:
        return error_result(f"{operation} failed for session {session}: {detail}")
    return error_result(f"{operation} failed for session {session}: launcher exited with code {code}")


def validate_session_url(url):
    if url is None:
        return None

    raw_url = str(url).strip()
    if not raw_url:
        return None

    if raw_url in ALLOWED_SESSION_URLS:
        return raw_url

    parsed = urllib_parse.urlsplit(raw_url)
    scheme = (parsed.scheme or "").lower()

    if scheme in ALLOWED_SESSION_SCHEMES:
        if not parsed.netloc:
            raise ValueError(
                "Rejected url: http and https URLs must include a host. Allowed values are "
                "http://, https://, clawbrowser://verify/, clawbrowser://auth, and about:blank."
            )
        return raw_url

    if scheme:
        raise ValueError(
            f"Rejected url scheme '{scheme}'. Allowed values are http://, https://, "
            "clawbrowser://verify/, clawbrowser://auth, and about:blank."
        )

    raise ValueError(
        "Rejected url value. Allowed values are http://, https://, "
        "clawbrowser://verify/, clawbrowser://auth, and about:blank."
    )


def normalize_endpoint(endpoint: str) -> str:
    endpoint = endpoint.strip().rstrip("/")
    parsed = urllib_parse.urlparse(endpoint)
    if parsed.scheme in {"ws", "wss"}:
        scheme = "http" if parsed.scheme == "ws" else "https"
        return f"{scheme}://{parsed.netloc}"
    return endpoint


def get_session_endpoint(arguments):
    code, stdout, stderr = run_launcher(["endpoint", "--session", normalize_session(arguments)])
    if code != 0:
        session = normalize_session(arguments)
        details = redact_sensitive_text(stderr or stdout)
        if details:
            return None, f"Could not get CDP endpoint for session {session}: {details}"
        return None, f"Could not get CDP endpoint for session {session}: launcher exited with code {code}"

    endpoint = stdout.splitlines()[-1].strip() if stdout else ""
    if not endpoint:
        return None, "launcher did not return a CDP endpoint"

    return endpoint, None


def fetch_json(url: str):
    with urllib_request.urlopen(url, timeout=2) as response:
        return json.load(response)


def session_http_endpoint(endpoint: str) -> str:
    return normalize_endpoint(endpoint)


def fetch_page_targets(endpoint: str):
    payload = fetch_json(f"{session_http_endpoint(endpoint)}/json/list")
    if not isinstance(payload, list):
        raise ValueError("unexpected /json/list payload")

    return [target for target in payload if target.get("type") == "page"]


def close_page_target(endpoint: str, target_id: str):
    url = (
        f"{session_http_endpoint(endpoint)}/json/close/"
        f"{urllib_parse.quote(str(target_id), safe='')}"
    )
    with urllib_request.urlopen(url, timeout=2) as response:
        return response.read().decode("utf-8", errors="replace").strip()


def run_launcher(args, api_key=None, image=None, timeout=90):
    env = os.environ.copy()
    if api_key:
        env["CLAWBROWSER_API_KEY"] = api_key
    else:
        env.pop("CLAWBROWSER_API_KEY", None)
    if image:
        env["CLAWBROWSER_IMAGE"] = image

    try:
        proc = subprocess.run(
            [launcher_path(), *args],
            capture_output=True,
            text=True,
            env=env,
            check=False,
            stdin=subprocess.DEVNULL,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return 124, "", f"clawbrowser launcher timed out after {timeout}s"

    stdout = proc.stdout.strip()
    stderr = proc.stderr.strip()
    return proc.returncode, stdout, stderr


def normalize_session(arguments):
    session = arguments.get("session") or arguments.get("session_name") or "default"
    return str(session)


def truthy(value) -> bool:
    if isinstance(value, bool):
        return value
    if value is None:
        return False
    return str(value).strip().lower() not in {"", "0", "false", "no", "off"}


def bad_fingerprint_value(value) -> bool:
    if value is None or isinstance(value, bool):
        return False
    return str(value).strip().lower() in {
        "0",
        "false",
        "no",
        "none",
        "off",
        "disabled",
        "disable",
        "no-fingerprint",
    }


def append_browser_args(args: list[str], arguments: dict) -> None:
    browser_args = []

    fingerprint = arguments.get("fingerprint")
    if bad_fingerprint_value(fingerprint):
        raise ValueError(
            "Invalid fingerprint override. Omit fingerprint for the launcher default, "
            "or pass true/a valid profile value."
        )
    if truthy(fingerprint):
        browser_args.append("--fingerprint")
        if not isinstance(fingerprint, bool) and str(fingerprint).strip().lower() not in {"1", "true", "yes", "on"}:
            browser_args.append(str(fingerprint))

    if arguments.get("regenerate"):
        browser_args.append("--regenerate")
    if arguments.get("verify_automation"):
        browser_args.append("--verify-automation")
    if arguments.get("country"):
        browser_args.append(f"--country={arguments['country']}")
    if arguments.get("connection_type"):
        browser_args.append(f"--connection-type={arguments['connection_type']}")

    url = validate_session_url(arguments.get("url"))
    if browser_args or url:
        args.append("--")
        args.extend(browser_args)
        if url:
            args.append(url)


def bootstrap_error():
    path = saved_config_path()
    return error_result(
        f"Clawbrowser can reuse the saved browser config at {path}. "
        "If it is missing, ask the user once for the real API key from "
        "https://app.clawbrowser.ai, pass it only as a high-risk "
        "bootstrap-only api_key tool argument when absolutely necessary, "
        "and let the launcher write the browser-managed config.json with mode 600. "
        "Never store the key in MCP config, agent config, shell rc files, or logs. "
        "For reauth, open clawbrowser://auth in Clawbrowser."
    )


def start_session(arguments):
    browser_has_key = saved_config_has_api_key()
    api_key = None if browser_has_key else next(
        (
            candidate
            for candidate in (
                os.environ.get("CLAWBROWSER_API_KEY"),
                arguments.get("api_key"),
            )
            if isinstance(candidate, str) and candidate.strip()
        ),
        None,
    )
    if not api_key and not browser_has_key:
        return bootstrap_error()

    args = ["start", "--session", normalize_session(arguments)]

    if port := arguments.get("port"):
        args.extend(["--port", str(port)])
    if image := arguments.get("image"):
        args.extend(["--image", str(image)])
    if arguments.get("verify"):
        args.append("--verify")
    try:
        append_browser_args(args, arguments)
    except ValueError as exc:
        return error_result(str(exc))

    code, stdout, stderr = run_launcher(args, api_key=api_key, image=arguments.get("image"))
    if code != 0:
        return launcher_failure("start_session", normalize_session(arguments), code, stdout, stderr, api_key=api_key)

    endpoint = stdout.splitlines()[-1].strip() if stdout else ""
    if not endpoint:
        return error_result(
            f"start_session failed for session {normalize_session(arguments)}: launcher did not return a CDP endpoint"
        )
    return text_result(endpoint)


def rotate_session(arguments):
    browser_has_key = saved_config_has_api_key()
    api_key = None if browser_has_key else next(
        (
            candidate
            for candidate in (
                os.environ.get("CLAWBROWSER_API_KEY"),
                arguments.get("api_key"),
            )
            if isinstance(candidate, str) and candidate.strip()
        ),
        None,
    )
    if not api_key and not browser_has_key:
        return bootstrap_error()

    args = ["rotate", "--session", normalize_session(arguments)]
    if image := arguments.get("image"):
        args.extend(["--image", str(image)])
    if arguments.get("verify"):
        args.append("--verify")
    try:
        append_browser_args(args, arguments)
    except ValueError as exc:
        return error_result(str(exc))

    code, stdout, stderr = run_launcher(args, api_key=api_key, image=arguments.get("image"))
    if code != 0:
        return launcher_failure("rotate_session", normalize_session(arguments), code, stdout, stderr, api_key=api_key)

    endpoint = stdout.splitlines()[-1].strip() if stdout else ""
    if not endpoint:
        return error_result(
            f"rotate_session failed for session {normalize_session(arguments)}: launcher did not return a CDP endpoint"
        )
    return text_result(endpoint)


def status_session(arguments):
    code, stdout, stderr = run_launcher(["status", "--session", normalize_session(arguments)])
    if code != 0:
        return launcher_failure("status_session", normalize_session(arguments), code, stdout, stderr)
    return text_result(stdout)


def endpoint_session(arguments):
    endpoint, error = get_session_endpoint(arguments)
    if error:
        details = error
        return error_result(details)
    return text_result(endpoint)


def list_tabs(arguments):
    endpoint, error = get_session_endpoint(arguments)
    if error:
        return error_result(error)

    try:
        targets = fetch_page_targets(endpoint)
    except Exception as exc:
        return error_result(f"Could not read tabs from {normalize_endpoint(endpoint)}: {exc}")

    return text_result(json.dumps(targets, indent=2, sort_keys=True))


def close_tabs(arguments):
    endpoint, error = get_session_endpoint(arguments)
    if error:
        return error_result(error)

    try:
        targets = fetch_page_targets(endpoint)
    except Exception as exc:
        return error_result(f"Could not read tabs from {normalize_endpoint(endpoint)}: {exc}")

    requested_ids = [str(target_id) for target_id in (arguments.get("target_ids") or []) if str(target_id).strip()]
    url_contains = arguments.get("url_contains")
    title_contains = arguments.get("title_contains")
    all_pages = bool(arguments.get("all_pages"))

    if requested_ids:
        selected = [target for target in targets if str(target.get("id")) in requested_ids]
        missing_target_ids = [target_id for target_id in requested_ids if target_id not in {str(target.get("id")) for target in selected}]
    elif url_contains or title_contains or all_pages:
        selected = targets
        missing_target_ids = []
        if url_contains:
            selected = [target for target in selected if url_contains in (target.get("url") or "")]
        if title_contains:
            selected = [target for target in selected if title_contains in (target.get("title") or "")]
    else:
        return error_result(
            "Specify target_ids, url_contains/title_contains, or all_pages=true."
        )

    if not selected:
        if requested_ids:
            summary = {
                "session": normalize_session(arguments),
                "endpoint": normalize_endpoint(endpoint),
                "closed": [],
                "missing_target_ids": missing_target_ids,
                "errors": [],
            }
            return error_result(json.dumps(summary, indent=2, sort_keys=True))
        return error_result("No matching tabs found.")

    closed = []
    errors = []
    for target in selected:
        target_id = str(target.get("id") or "").strip()
        if not target_id:
            continue

        try:
            response_text = close_page_target(endpoint, target_id)
            closed.append(
                {
                    "id": target_id,
                    "title": target.get("title", ""),
                    "url": target.get("url", ""),
                    "response": response_text,
                }
            )
        except urllib_error.HTTPError as exc:
            if exc.code == 404:
                errors.append({"id": target_id, "error": "Target not found"})
            else:
                errors.append({"id": target_id, "error": f"HTTP {exc.code}"})
        except Exception as exc:
            errors.append({"id": target_id, "error": str(exc)})

    summary = {
        "session": normalize_session(arguments),
        "endpoint": normalize_endpoint(endpoint),
        "closed": closed,
        "missing_target_ids": missing_target_ids,
        "errors": errors,
    }

    if errors and not closed:
        return error_result(json.dumps(summary, indent=2, sort_keys=True))

    return text_result(json.dumps(summary, indent=2, sort_keys=True))


def stop_session(arguments):
    code, stdout, stderr = run_launcher(["stop", "--session", normalize_session(arguments)])
    if code != 0:
        return launcher_failure("stop_session", normalize_session(arguments), code, stdout, stderr)
    return text_result(stdout or "stopped")


def list_profiles(arguments):
    code, stdout, stderr = run_launcher(["list", "--session", normalize_session(arguments)])
    if code != 0:
        return launcher_failure("list_profiles", normalize_session(arguments), code, stdout, stderr)
    return text_result(stdout)


